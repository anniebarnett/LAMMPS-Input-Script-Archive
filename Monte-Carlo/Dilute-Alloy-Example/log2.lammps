variable swap_counter loop ${steps_per_loop}
variable swap_counter loop 500
label loop_swap
  restart 100000 restart.*
  variable seed equal floor(random(1,1000000,12345))

  variable t1 equal 1
  variable t2 equal 3

  print "t1: ${t1}"
t1: 1
  print "t2: ${t2}"
t2: 3

  fix swaprand all atom/swap ${MC_steps} ${nswaps} ${seed} ${Temp_aging} types ${t1} ${t2}
  fix swaprand all atom/swap 25 ${nswaps} ${seed} ${Temp_aging} types ${t1} ${t2}
  fix swaprand all atom/swap 25 150 ${seed} ${Temp_aging} types ${t1} ${t2}
  fix swaprand all atom/swap 25 150 560125 ${Temp_aging} types ${t1} ${t2}
  fix swaprand all atom/swap 25 150 560125 573.15 types ${t1} ${t2}
  fix swaprand all atom/swap 25 150 560125 573.15 types 1 ${t2}
  fix swaprand all atom/swap 25 150 560125 573.15 types 1 3
  thermo 50
  thermo_style custom step temp atoms c_eatoms v_time_tot ke etotal press vol lx ly lz f_swaprand[1] f_swaprand[2]
  run ${steps}
  run 500
