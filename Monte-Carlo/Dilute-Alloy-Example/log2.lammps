  fix swaprand all atom/swap 25 150 666839 573.15 types 1 ${t2}
  fix swaprand all atom/swap 25 150 666839 573.15 types 1 3
  thermo 50
  thermo_style custom step temp atoms c_eatoms v_time_tot ke etotal press vol lx ly lz f_swaprand[1] f_swaprand[2]
  run ${steps}
  run 500
