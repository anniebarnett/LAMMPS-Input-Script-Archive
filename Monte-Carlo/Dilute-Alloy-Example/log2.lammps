LAMMPS (2 Aug 2023 - Update 3)
# Homogenization, aging and calcul-ate ordering in MoTa alloys
# potential: tabGAP overlay with EAM for MoNbTaWV
#
# Annie Barnett Sept 2024 (NRL)
# A2 regime for this alloy is 572-3000K
# B2 regime for this alloy is 0-500K
# A2 + B2 for this alloy is 500-572K
################################################################################
#---------------------------- Simulation Setup --------------------------------#
################################################################################

#--- Initialization ---#
units           metal
#dimension       3
#boundary        p p p
#atom_style      atomic

read_restart ./restart.500000
Reading restart file ...
  restart file = 2 Aug 2023, LAMMPS = 2 Aug 2023
  restoring atom style atomic from restart
  orthogonal box = (-85.833207 -85.829929 -85.822202) to (85.833207 85.829929 85.822202)
  8 by 6 by 5 MPI processor grid
  pair style hybrid/overlay stores no restart info
  314928 atoms
  read_restart CPU = 21.105 seconds

#--- Variables1 ---#
variable        time_tot        equal "(dt*step)/1000" #nanoseconds
variable        composition     string MoTa
variable        Temp_aging      equal 573.15   #300C
variable        latparam        equal 3.31
variable 	seed 		equal 	floor(random(1,1000000,12345))

#--- Create Lattice ---#
#lattice        bcc ${latparam} orient x 1 0 0 orient y 0 1 0 orient z 0 0 1
#region         whole block -27 27 -27 27 -27 27 units lattice
#create_box     5 whole
#create_atoms   1 box

#set type 1 type/ratio 3 0.050 73932

mass 1 95.95    #Mo
mass 2 92.90637 #Nb
mass 3 180.94788 #Ta
mass 4 50.9415 #V
mass 5 183.84   #W

#--- Interactions ---#
pair_style hybrid/overlay tabgap eam/fs
pair_coeff * * tabgap /home/abarne65/scratch16-mfalk1/annie/defects/Mo-Nb-Ta-V-W.tabgap Mo Nb Ta V W no yes
Reading tabgap potential file /home/abarne65/scratch16-mfalk1/annie/defects/Mo-Nb-Ta-V-W.tabgap with DATE: 2021-10-10
pair_coeff * * eam/fs /home/abarne65/scratch16-mfalk1/annie/defects/Mo-Nb-Ta-V-W.eam.fs Mo Nb Ta V W
Reading eam/fs potential file /home/abarne65/scratch16-mfalk1/annie/defects/Mo-Nb-Ta-V-W.eam.fs with DATE: 2021-10-10

#reset_timestep 0
timestep .002 #picoseconds

#--- Neighbor Cuttoff ---#
neighbor 2.0 bin
neigh_modify delay 10 every 1 check yes

#--- Computes ---#
compute potEnergy all pe/atom
compute eatoms all reduce sum c_potEnergy
compute kinEnergy all ke/atom
compute csym all centro/atom bcc                #centrosymmetry parameter

compute sigma all stress/atom NULL virial       #per atom stress tensor (symmetric, 6 components below)
compute aveSigma1 all reduce sum c_sigma[1]     #xx
compute aveSigma2 all reduce sum c_sigma[2]     #yy
compute aveSigma3 all reduce sum c_sigma[3]     #zz
compute aveSigma4 all reduce sum c_sigma[4]     #xy
compute aveSigma5 all reduce sum c_sigma[5]     #xz
compute aveSigma6 all reduce sum c_sigma[6]     #yz

################################################################################
#---------------------------------- Aging -------------------------------------#
################################################################################
#--- MC/MD ---#
thermo 10
thermo_style custom step temp atoms c_eatoms v_time_tot ke etotal press vol lx ly lz

dump d2 all custom 10000 ${composition}-${Temp_aging}_mcmd.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6]
dump d2 all custom 10000 MoTa-${Temp_aging}_mcmd.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6]
dump d2 all custom 10000 MoTa-573.15_mcmd.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6]
dump_modify d2 element Mo Nb Ta V W
dump_modify d2 sort id

velocity all create ${Temp_aging} 8837211 mom yes rot yes dist gaussian
velocity all create 573.15 8837211 mom yes rot yes dist gaussian

fix age all npt temp ${Temp_aging} ${Temp_aging} $(100*dt) aniso 0.0 0.0 $(1000*dt)
fix age all npt temp 573.15 ${Temp_aging} $(100*dt) aniso 0.0 0.0 $(1000*dt)
fix age all npt temp 573.15 573.15 $(100*dt) aniso 0.0 0.0 $(1000*dt)
fix age all npt temp 573.15 573.15 0.2000000000000000111 aniso 0.0 0.0 $(1000*dt)
fix age all npt temp 573.15 573.15 0.2000000000000000111 aniso 0.0 0.0 2

variable nswaps equal 150
variable steps equal 500
variable MC_steps equal 25
variable steps_per_loop equal 500
variable total_steps equal 10000000
variable iter equal ${total_steps}/${steps_per_loop}
variable iter equal 10000000/${steps_per_loop}
variable iter equal 10000000/500
variable loopmdmc_counter loop ${iter}
variable loopmdmc_counter loop 20000

#----------------------- Randomized pair swap definitions ----------------------#
label loop_mdmc
print "#### Begin MC ####"
#### Begin MC ####

run ${steps}
run 500
Unused restart file global fix info:
  fix style: atom/swap, fix ID: swaprand
Neighbor list info ...
  update: every = 1 steps, delay = 10 steps, check = yes
  max neighbors/atom: 2000, page size: 100000
  master list distance cutoff = 7
  ghost atom cutoff = 7
  binsize = 3.5, bins = 50 50 50
  3 neighbor lists, perpetual/occasional/extra = 2 1 0
  (1) pair tabgap, perpetual
      attributes: full, newton on, cut 6.1
      pair build: full/bin/atomonly
      stencil: full/bin/3d
      bin: standard
  (2) pair eam/fs, perpetual
      attributes: half, newton on
      pair build: half/bin/atomonly/newton
      stencil: half/bin/3d
      bin: standard
  (3) compute centro/atom, occasional
      attributes: full, newton on
      pair build: full/bin/atomonly
      stencil: full/bin/3d
      bin: standard
