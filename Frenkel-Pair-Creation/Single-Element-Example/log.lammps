Ave neighs/atom = 112
Neighbor list builds = 0
Dangerous builds = 0

variable counter_interstitials equal 0
velocity all create ${Temp} 7392611 mom yes rot yes dist gaussian
velocity all create 573 7392611 mom yes rot yes dist gaussian

write_dump all custom ${comp}_*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]
write_dump all custom Ni_*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]

#--- Loop to generate Frenkel pairs ---#
variable        n loop 2
label           loop

variable fppl equal 2	## FPPL = FRENKEL PAIRS PER LOOP -> CHANGE THIS VALUE TO CHANGE THE 'DOSE RATE' OF YOUR SIMULATION ###
variable deposteps equal 10
variable rate  equal ${deposteps}/${fppl}
variable rate  equal 10/${fppl}
variable rate  equal 10/2
variable dumprate equal ${deposteps}/2
variable dumprate equal 10/2
variable quenchsteps equal 100

#--- NPT relaxation ---#
fix npt all npt temp ${Temp} ${Temp} $(100*dt) aniso 0.0 0.0 $(1000*dt)
fix npt all npt temp 573 ${Temp} $(100*dt) aniso 0.0 0.0 $(1000*dt)
fix npt all npt temp 573 573 $(100*dt) aniso 0.0 0.0 $(1000*dt)
fix npt all npt temp 573 573 0.050000000000000002776 aniso 0.0 0.0 $(1000*dt)
fix npt all npt temp 573 573 0.050000000000000002776 aniso 0.0 0.0 0.5

dump d2 all custom ${dumprate} ${comp}_npt${n}_${Temp}C.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump d2 all custom 5 ${comp}_npt${n}_${Temp}C.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump d2 all custom 5 Ni_npt${n}_${Temp}C.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump d2 all custom 5 Ni_npt1_${Temp}C.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump d2 all custom 5 Ni_npt1_573C.*.dump id type element mass x y z c_csym c_potEnergy c_kinEnergy c_sigma[1] c_sigma[2] c_sigma[3] c_sigma[4] c_sigma[5] c_sigma[6] c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump_modify d2 element Ni Al
dump_modify d2 sort id

#--- Box Settings ---#
region lattice_region_${n} block EDGE EDGE EDGE EDGE EDGE EDGE units box
region lattice_region_1 block EDGE EDGE EDGE EDGE EDGE EDGE units box

#-- Assign Interstitials ---#
#variable atype_unfiltered equal ceil(random(1,2,19299272))  # Randomly select atom type between 1 and 2
variable atype_unfiltered equal 1
print "selected atom type = ${atype_unfiltered}"
selected atom type = 1
variable atype equal ${atype_unfiltered}
variable atype equal 1

#--- Create Vacancies ---#
variable num_delete_atoms equal ${fppl}
variable num_delete_atoms equal 2
group vacancy_atoms type ${atype}
group vacancy_atoms type 1
32000 atoms in group vacancy_atoms
delete_atoms random count ${num_delete_atoms} yes vacancy_atoms NULL 263721
delete_atoms random count 2 yes vacancy_atoms NULL 263721
Deleted 2 atoms, new total = 31998

#--- Create Interstitials ---#
fix depo all deposit ${fppl} ${atype} ${rate} 254921 region lattice_region_${n} near 0.5 attempt 100 id max
fix depo all deposit 2 ${atype} ${rate} 254921 region lattice_region_${n} near 0.5 attempt 100 id max
fix depo all deposit 2 1 ${rate} 254921 region lattice_region_${n} near 0.5 attempt 100 id max
fix depo all deposit 2 1 5 254921 region lattice_region_${n} near 0.5 attempt 100 id max
fix depo all deposit 2 1 5 254921 region lattice_region_1 near 0.5 attempt 100 id max

thermo 50
thermo_style custom step temp atoms c_eatoms v_time_tot ke etotal press vol lx ly lz c_msd_t1[1] c_msd_t1[2] c_msd_t1[3] c_msd_t1[4] c_msd_t2[1] c_msd_t2[2] c_msd_t2[3] c_msd_t2[4]
thermo_modify lost ignore flush yes

run   ${deposteps}
run   10
